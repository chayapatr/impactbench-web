PUBLIC_SUPABASE_URL=https://tsaobsvruacdusomvftf.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key

# ── Local-only: /metrics-admin pipeline bridge ────────────────────────────
# Both of these are required for the "Generate Scenarios" real-run button to
# work. Leave both unset in any deployed environment — the bridge spawns a
# local python subprocess against a sibling git checkout and a real venv, so
# it only ever works on a dev machine with the impactbench repo checked out
# beside this one.

# Path to the sibling impactbench (bench-py) repo, absolute or relative to
# this repo's root.
PIPELINE_REPO_PATH=../impactbench

# Server-only — never PUBLIC_. Bypasses RLS so the bridge can read real
# provider API keys (to inject into the pipeline subprocess's environment)
# and write generation results back in. Get it from Supabase Settings -> API
# -> Project API keys -> service_role. Never commit a populated value.
SUPABASE_SERVICE_ROLE_KEY=

# After updating supabase/schema.sql, re-run it in the Supabase SQL editor
# so SECURITY DEFINER RPCs, RLS, and revoked grants are applied.
#
# Dashboard checklist (Settings → API / Database):
# - Use the anon/publishable key in the browser — never the service_role key.
# - Keep only intended schemas exposed to the Data API (typically `public`).
# - Leave Realtime disabled for experts / expert_evaluations unless needed.
# - Confirm table privileges stay revoked for anon/authenticated (RPC-only).
